# ─── Container ────────────────────────────────────────────────
CONTAINER_NAME=DK_GAME_CLIENTE

# ─── Frontend (build args) ─────────────────────────────────────
VITE_API_URL=https://game-cliente.eventifylab.com
VITE_API_TOKEN=seu_token_aqui
VITE_PRIMARY_COLOR=#005844
VITE_GAME_TITLE=Game Roleta

# ─── API / Banco ───────────────────────────────────────────────
DB_HOST=DK_POSTGRES
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=senha_aqui
DB_NAME=game_cliente
TENANT_ID=10

# ─── Manager DB (para validar chave de API / eventos) ─────────
MANAGER_DB_NAME=mydb

# ─── Auth ──────────────────────────────────────────────────────
JWT_SECRET=segredo_jwt_aqui
MANAGER_USER=admin
MANAGER_PASS=senha_manager
ENTREGA_PASS=senha_entrega

# ─── Quiz ──────────────────────────────────────────────────────
QUIZ_MIN_ACERTOS=2
